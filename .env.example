# Shared defaults used by all three apps when app-specific values are not set.
VITE_CHAIN_ID=11155111
VITE_CHAIN_NAME=Sepolia
VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VITE_READ_RPC_URL=/rpc/sepolia
VITE_ERC20_ADDRESS=
VITE_DEFAULT_QUERY_ADDRESS=
VITE_DEFAULT_RECIPIENT=

# Optional per-app overrides for Vercel or root builds.
# ethers reads VITE_ETHERS_* first, then falls back to the shared VITE_* values above.
VITE_ETHERS_CHAIN_ID=
VITE_ETHERS_CHAIN_NAME=
VITE_ETHERS_RPC_URL=
VITE_ETHERS_READ_RPC_URL=
VITE_ETHERS_ERC20_ADDRESS=
VITE_ETHERS_DEFAULT_QUERY_ADDRESS=
VITE_ETHERS_DEFAULT_RECIPIENT=

# viem reads VITE_VIEM_* first, then falls back to shared VITE_* values.
VITE_VIEM_CHAIN_ID=
VITE_VIEM_CHAIN_NAME=
VITE_VIEM_RPC_URL=
VITE_VIEM_READ_RPC_URL=
VITE_VIEM_ERC20_ADDRESS=
VITE_VIEM_DEFAULT_QUERY_ADDRESS=
VITE_VIEM_DEFAULT_RECIPIENT=

# wagmi reads VITE_WAGMI_* first, then falls back to shared VITE_* values.
VITE_WAGMI_CHAIN_ID=
VITE_WAGMI_CHAIN_NAME=
VITE_WAGMI_RPC_URL=
VITE_WAGMI_READ_RPC_URL=
VITE_WAGMI_ERC20_ADDRESS=
VITE_WAGMI_DEFAULT_QUERY_ADDRESS=
VITE_WAGMI_DEFAULT_RECIPIENT=
